DATA_SOURCE="postgres"
NEXT_PUBLIC_APP_NAME="StockGI Soporte TI"
APP_BASE_URL="https://soporte.stockgi.com"
APP_PORT="3002"
POSTGRES_MIGRATOR_PASSWORD="CHANGE_ME_MIGRATOR_PASSWORD"
POSTGRES_APP_PASSWORD="CHANGE_ME_APP_PASSWORD"
DATABASE_URL="postgresql://stockgi_app:${POSTGRES_APP_PASSWORD}@postgres:5432/stockgi_soporte_ti"
MIGRATION_DATABASE_URL="postgresql://stockgi_migrator:${POSTGRES_MIGRATOR_PASSWORD}@postgres:5432/stockgi_soporte_ti"
SESSION_SECRET="CHANGE_ME_64_RANDOM_CHARS"
SESSION_TTL_HOURS="8"
SESSION_COOKIE_SECURE="true"
UPLOAD_STORAGE_PATH="/var/lib/stockgi/uploads"
MAX_ATTACHMENT_MB="10"
ATTACHMENT_RETENTION_DAYS="30"
CLOUDFLARE_TUNNEL_TOKEN=""
COMPOSE_PROJECT_NAME="stk-soporte"
